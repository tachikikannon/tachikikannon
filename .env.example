# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — Project Settings > API > service_role（絶対に公開しない。サーバー専用）
# 管理者アカウント作成（/admin/users）でのみ使用します。
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# メール通知 — resend.com で取得
RESEND_API_KEY=re_xxxxxxxxxxxx

# 予約・お問い合わせの通知先メールアドレス（お寺のメールアドレス）
NOTIFY_EMAIL=info@example.com

# サイトの本番URL（LINE通知内の管理画面リンク生成に使用。末尾スラッシュなし）
SITE_URL=https://your-site.vercel.app

# LINE Messaging API — LINE Developers コンソールで取得（サーバー専用）
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx...
# Botを招待した寺務所LINEグループのgroupId（/api/line/webhook のログから取得）
LINE_RESERVATION_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
